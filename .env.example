NODE_ENV=development
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=1d

# Docker default values:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geoplatform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSL=false

AUTH_SERVICE_PORT=3001
TOURS_SERVICE_PORT=3002
LOCATION_SERVICE_PORT=3003
GATEWAY_PORT=3000

# Docker default service discovery URLs:
AUTH_SERVICE_URL=http://auth-users-service:3001
TOURS_SERVICE_URL=http://tours-service:3002
LOCATION_SERVICE_URL=http://location-service:3003
